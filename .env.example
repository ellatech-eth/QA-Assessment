# Copy this file to `.env` and adjust the values for your environment:
#   cp .env.example .env
#
# These variables are read by the NestJS app (src/app.module.ts),
# the TypeORM CLI (data-source.ts) and Docker Compose.

# ---- Application ----
PORT=4000

# ---- Database (PostgreSQL) ----
# When running the app locally against the Docker DB, use localhost.
# When running the app *inside* Docker Compose, DB_HOST is overridden to `db`.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=ella
